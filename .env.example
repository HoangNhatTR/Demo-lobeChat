# ==============================================
#  GitLab Tool Server Configuration
# ==============================================

# GitLab Personal Access Token (required)
# Generate at: https://gitlab.com/-/user_settings/personal_access_tokens
# Scopes needed: api, read_api, read_repository
GITLAB_TOKEN=glpat-iTzb8NpsjtkMmFN81s9rrm86MQp1OmNyeW83Cw.01.120rn7mxf


# GitLab API URL (default: gitlab.com)
# For self-hosted: https://your-gitlab.example.com/api/v4
GITLAB_API_URL=https://gitlab.com/api/v4

# ==============================================
#  Jira Tool Server Configuration
# ==============================================

# Jira Base URL (required)
# For Jira Cloud: https://your-domain.atlassian.net
# For Jira Server: https://your-jira-server.example.com
JIRA_BASE_URL = https://jira.protontech.vn

# Jira Email (required for Cloud — the email of your Atlassian account)
JIRA_EMAIL= .........@protontech.vn

# Jira API Token (required)
# Generate at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN = ..........

# ==============================================
#  Confluence Tool Server Configuration
# ==============================================

# Confluence Base URL (required)
# For Confluence Cloud: https://your-domain.atlassian.net
# For Confluence Server: https://your-confluence-server.example.com
CONFLUENCE_BASE_URL=https://confluence.your-company.com

# Confluence Email (required for Cloud only)
CONFLUENCE_EMAIL=..........@example.com

# Confluence API Token / Personal Access Token (required)
# Cloud: https://id.atlassian.com/manage-profile/security/api-tokens
# Server: Profile → Personal Access Tokens
CONFLUENCE_API_TOKEN=..........

# ==============================================
#  MetaGPT Multi-Agent Orchestrator Configuration
# ==============================================

# LLM API endpoint (OpenAI-compatible)
# Ollama:  http://192.168.3.7:11434/v1/chat/completions
# OpenAI:  https://api.openai.com/v1/chat/completions
# METAGPT_LLM_API_URL=http://192.168.3.7:11434/v1/chat/completions

# # API Key (use "ollama" for Ollama, or your actual API key for OpenAI/others)
# METAGPT_LLM_API_KEY=ollama

# # Default model for all agents
# # Ollama examples: qwen3.5:latest, deepseek-coder-v2:latest, llama3:latest
# # OpenAI examples: gpt-4o, gpt-4-turbo
# METAGPT_LLM_MODEL=qwen3.5:latest

# # Per-agent model overrides (optional — leave empty to use default)
# # PM & Architect benefit from strong reasoning models
# # Engineer benefits from coding-specialized models
# METAGPT_LLM_MODEL_PM=
# METAGPT_LLM_MODEL_ARCHITECT=
# METAGPT_LLM_MODEL_ENGINEER=deepseek-coder-v2:latest
# METAGPT_LLM_MODEL_QA=

# # Temperature (0.0-1.0, higher = more creative)
# METAGPT_LLM_TEMPERATURE=0.7

# # Max tokens per LLM response
# METAGPT_LLM_MAX_TOKENS=8192


# Thay đổi từ Ollama sang OpenRouter
METAGPT_LLM_API_URL=https://openrouter.ai/api/v1/chat/completions
METAGPT_LLM_API_KEY=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   # key mới (revoke key cũ đã lộ!)
METAGPT_LLM_MODEL=anthropic/claude-sonnet-4-20250514   # hoặc model khác trên OpenRouter
METAGPT_LLM_MAX_TOKENS=8192

# Có thể dùng model khác cho Engineer
METAGPT_LLM_MODEL_ENGINEER=deepseek/deepseek-coder
